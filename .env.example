# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Feature Flags (provider selection)
# USE_META=true          # Use Meta Cloud API (official) - takes precedence
# USE_ZAPI=true          # Use Z-API
# META_WEBHOOK_ENABLED=true  # Enable /webhook/meta endpoint
# ZAPI_WEBHOOK_ENABLED=true  # Enable /webhook/zapi endpoint

# Meta Cloud API Configuration (when USE_META=true)
WHATSAPP_ACCESS_TOKEN=your-meta-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_WEBHOOK_TOKEN=your-webhook-verify-token
META_API_VERSION=v22.0

# Evolution API Configuration (legacy)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-api-key-here
EVOLUTION_INSTANCE=meu-zap

# Z-API Configuration (legacy)
# Z_API_INSTANCE=your-instance
# Z_API_TOKEN=your-token
# Z_API_CLIENT_TOKEN=your-client-token
