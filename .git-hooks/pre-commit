#!/bin/sh

# ============================================================
# PRE-COMMIT HOOK - Seguranca + Documentacao
# ============================================================
#
# Este hook:
# 1. BLOQUEIA commits com secrets/senhas
# 2. Lembra de atualizar documentacao de fluxos
#
# Para instalar:
# cp .git-hooks/pre-commit .git/hooks/pre-commit
# chmod +x .git/hooks/pre-commit

echo ""
echo "🔍 Pre-commit: verificando..."

# ============================================================
# 1. DETECCAO DE SECRETS (BLOQUEIA COMMIT)
# ============================================================

# Padroes de secrets comuns
SECRET_PATTERNS="
eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9
sk_live_
sk_test_
AKIA[0-9A-Z]{16}
ghp_[a-zA-Z0-9]{36}
gho_[a-zA-Z0-9]{36}
xox[baprs]-[0-9]{10,13}-[0-9]{10,13}-[a-zA-Z0-9]{24}
-----BEGIN (RSA |DSA |EC |OPENSSH |PGP )?PRIVATE KEY-----
password\s*=\s*['\"][^'\"]+['\"]
api_key\s*=\s*['\"][^'\"]+['\"]
secret\s*=\s*['\"][^'\"]+['\"]
"

# Arquivos/diretorios a ignorar na checagem
IGNORE_FILES="\.example$|\.sample$|\.md$|package\.json$|package-lock\.json$|\.git-hooks/|pre-commit"

# Verifica arquivos staged
SECRETS_FOUND=0
for pattern in $SECRET_PATTERNS; do
  # Pula linhas vazias
  [ -z "$pattern" ] && continue

  # Busca pattern nos arquivos staged (exceto os ignorados)
  MATCHES=$(git diff --cached --diff-filter=ACMR -U0 | grep -E "^\+" | grep -v "^+++" | grep -E "$pattern" | grep -vE "$IGNORE_FILES" | head -3)

  if [ -n "$MATCHES" ]; then
    if [ $SECRETS_FOUND -eq 0 ]; then
      echo ""
      echo "🚨 ERRO: Possivel SECRET detectado nos arquivos!"
      echo ""
    fi
    echo "   Pattern: $pattern"
    echo "$MATCHES" | head -3 | sed 's/^/   /'
    echo ""
    SECRETS_FOUND=1
  fi
done

if [ $SECRETS_FOUND -eq 1 ]; then
  echo "❌ COMMIT BLOQUEADO!"
  echo ""
  echo "   Remova os secrets dos arquivos antes de commitar."
  echo "   Use Doppler para gerenciar secrets: doppler run npm run dev"
  echo ""
  echo "   Para bypass (USE COM CUIDADO):"
  echo "   git commit --no-verify"
  echo ""
  exit 1
fi

echo "   ✅ Nenhum secret detectado"

# ============================================================
# 2. VERIFICACAO DE .env FILES
# ============================================================

# Verifica se algum .env esta sendo commitado (exceto .example)
ENV_FILES=$(git diff --cached --name-only | grep -E "^\.env" | grep -v "\.example$")

if [ -n "$ENV_FILES" ]; then
  echo ""
  echo "🚨 ERRO: Arquivos .env detectados no commit!"
  echo ""
  echo "   Arquivos:"
  echo "$ENV_FILES" | sed 's/^/   - /'
  echo ""
  echo "   Arquivos .env NUNCA devem ser commitados!"
  echo "   Use Doppler para gerenciar secrets."
  echo ""
  echo "   Para remover do staging:"
  echo "   git reset HEAD <arquivo>"
  echo ""
  exit 1
fi

# ============================================================
# 3. LEMBRETE DE DOCUMENTACAO
# ============================================================

# Arquivos que afetam fluxos documentados
# IMPORTANTE: Adicione novos arquivos criticos aqui!
# Ultima atualizacao: 11/01/2026
FLOW_FILES="
src/routes/webhook.ts
src/worker.ts
src/config/queue.ts
src/services/menuService.ts
src/services/subscriptionService.ts
src/services/atomicLimitService.ts
src/services/experimentService.ts
src/services/onboardingService.ts
src/services/pixPaymentService.ts
src/services/userService.ts
src/utils/supabaseRpc.ts
src/types/subscription.ts
src/jobs/resetDailyCounters.ts
src/jobs/sendPendingStickers.ts
src/jobs/sendScheduledReminders.ts
"

# Arquivos críticos do admin panel
ADMIN_CRITICAL_FILES="admin-panel/src/lib/supabase/client.ts admin-panel/src/lib/supabase/server.ts admin-panel/middleware.ts admin-panel/src/hooks/useAuth.ts admin-panel/src/app/login/"

# Verifica se algum desses arquivos foi modificado
CHANGED_FLOW_FILES=""
for file in $FLOW_FILES; do
  if git diff --cached --name-only | grep -q "^$file$"; then
    CHANGED_FLOW_FILES="$CHANGED_FLOW_FILES\n  - $file"
  fi
done

CHANGED_ADMIN_FILES=""
for file in $ADMIN_CRITICAL_FILES; do
  if git diff --cached --name-only | grep -q "^$file"; then
    CHANGED_ADMIN_FILES="$CHANGED_ADMIN_FILES\n  - $file"
  fi
done

# Se houve mudancas no bot, avisa o usuario
if [ -n "$CHANGED_FLOW_FILES" ]; then
  echo ""
  echo "⚠️  ATENCAO: Voce alterou arquivos de fluxo do bot!"
  echo ""
  echo "📝 Arquivos modificados:$CHANGED_FLOW_FILES"
  echo ""
  echo "📋 Lembre-se de atualizar a documentacao:"
  echo "   -> docs/architecture/FLOWCHARTS.md"
  echo "   -> docs/architecture/ARCHITECTURE.md (se necessario)"
  echo "   -> CHANGELOG.md"
  echo ""

  # Verifica se FLOWCHARTS.md foi modificado tambem
  if git diff --cached --name-only | grep -q "docs/architecture/FLOWCHARTS.md"; then
    echo "✅ FLOWCHARTS.md foi modificado neste commit. Otimo!"
    echo ""
  else
    echo "❌ FLOWCHARTS.md NAO foi modificado neste commit."
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "⚠️  VOCE MODIFICOU FLUXOS CRITICOS DO BOT!"
    echo ""
    echo "📋 Antes de continuar, confirme:"
    echo "   [ ] Li o codigo e entendi as mudancas"
    echo "   [ ] Atualizarei FLOWCHARTS.md IMEDIATAMENTE apos este commit"
    echo "   [ ] Esta e uma emergencia (hotfix critico em producao)"
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "Deseja continuar SEM atualizar a documentacao agora? (y/n)"
    echo -n "→ "
    read -r response

    if [ "$response" != "y" ] && [ "$response" != "Y" ]; then
      echo ""
      echo "❌ Commit cancelado. Atualize a documentacao e tente novamente."
      echo ""
      echo "💡 Dica: Edite docs/architecture/FLOWCHARTS.md e rode 'git add' novamente"
      echo ""
      exit 1
    fi

    echo ""
    echo "⚠️  ATENCAO: Commit prosseguindo SEM documentacao atualizada!"
    echo "⚠️  LEMBRE-SE: Atualize FLOWCHARTS.md no PROXIMO commit!"
    echo ""
  fi
fi

# Se houve mudancas no admin panel, avisa o usuario
if [ -n "$CHANGED_ADMIN_FILES" ]; then
  echo ""
  echo "⚠️  ATENCAO: Voce alterou arquivos criticos do Admin Panel!"
  echo ""
  echo "📝 Arquivos modificados:$CHANGED_ADMIN_FILES"
  echo ""
  echo "📋 CHECKLIST OBRIGATORIO:"
  echo "   ✅ Testou localmente? (doppler run -- npm run dev)"
  echo "   ✅ Build passa? (npm run build)"
  echo "   ✅ Login funciona?"
  echo "   ✅ Queries executam?"
  echo "   ✅ Atualizou CHANGELOG.md?"
  echo ""
  echo "📄 Documentacao:"
  echo "   -> CHANGELOG.md"
  echo "   -> docs/ADMIN_PANEL_DEPLOYMENT.md"
  echo "   -> docs/decisions/ (se decisao arquitetural)"
  echo ""

  # Verifica se CHANGELOG foi modificado
  if git diff --cached --name-only | grep -q "CHANGELOG.md"; then
    echo "✅ CHANGELOG.md foi modificado neste commit. Otimo!"
    echo ""
  else
    echo "❌ CHANGELOG.md NAO foi modificado neste commit."
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "🚨 VOCE MODIFICOU ARQUIVOS CRITICOS DO ADMIN PANEL!"
    echo ""
    echo "⚠️  CONSEQUENCIAS de commit sem documentacao:"
    echo "   • Dificuldade de debugging em producao"
    echo "   • Time nao saberá o que mudou"
    echo "   • Quebra do processo de deploy"
    echo "   • Historico incompleto para auditorias"
    echo ""
    echo "📋 Checklist obrigatorio:"
    echo "   [ ] Testei localmente (doppler run -- npm run dev)"
    echo "   [ ] Build passa (npm run build)"
    echo "   [ ] Login funciona"
    echo "   [ ] Queries executam"
    echo "   [ ] Esta e uma emergencia (hotfix em producao)"
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "Deseja continuar SEM atualizar CHANGELOG.md? (y/n)"
    echo -n "→ "
    read -r response

    if [ "$response" != "y" ] && [ "$response" != "Y" ]; then
      echo ""
      echo "❌ Commit cancelado. Atualize o CHANGELOG.md e tente novamente."
      echo ""
      echo "💡 Dica: Adicione entrada em CHANGELOG.md secao [Nao Publicado]"
      echo ""
      exit 1
    fi

    echo ""
    echo "⚠️  ATENCAO: Commit prosseguindo SEM CHANGELOG atualizado!"
    echo "🚨 CRITICO: Atualize CHANGELOG.md ANTES do deploy em producao!"
    echo ""
  fi
fi

echo "✅ Pre-commit: OK"
echo ""

exit 0
